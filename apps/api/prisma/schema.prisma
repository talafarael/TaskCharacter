generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ScheduleType {
  ONE_TIME
  WEEKLY
  TWO_WEEKLY
}

enum Day {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

type ScheduleSlot {
  day       Day
  timeSlots String[]
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  name     String
  password String

  characters    Character[]
}

model Character {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  questTemplates QuestTemplate[]
  name       String
  stats       Stats?

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
}

model Stats {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  gold         Int    @default(0)
  experience   Int    @default(0)
  level        Int    @default(1)
  strength     Int    @default(10)
  agility      Int    @default(10)
  intelligence Int    @default(10)

  characterId    String @unique @db.ObjectId
  character      Character @relation(fields: [characterId], references: [id])
}

model QuestTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  scheduledTime ScheduledTime?
  lastUsed DateTime?

  questInstances Quest[]

  characterId String   @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])
}

model Quest {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  isCompleted Boolean @default(false)
  completedAt DateTime?

  questTemplateId String @db.ObjectId
  questTemplate   QuestTemplate @relation(fields: [questTemplateId], references: [id])
}


type SpecificDate {
  // id     String @id @default(auto()) @map("_id") @db.ObjectId
  date   DateTime
  // scheduledTimeId String @db.ObjectId
  // scheduledTime   ScheduledTime @relation(fields: [scheduledTimeId], references: [id])
}

model ScheduledTime {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  type   ScheduleType
  specificDates SpecificDate[]
  scheduleSlots ScheduleSlot[]

  questTemplateId String @unique @db.ObjectId
  questTemplate   QuestTemplate @relation(fields: [questTemplateId], references: [id])
}
